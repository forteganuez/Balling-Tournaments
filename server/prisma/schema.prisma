generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Sport {
  PADEL
  TENNIS
  SQUASH
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
}

enum TournamentStatus {
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserRole {
  PLAYER
  ORGANIZER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
  MICROSOFT
}

enum PlayLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum MatchType {
  CASUAL
  COMPETITIVE
}

enum MatchFormat {
  SINGLES
  DOUBLES
}

enum CompetitiveMatchStatus {
  CREATED
  AWAITING_OPPONENT
  ACTIVE
  COMPLETED
  DISPUTED
  CANCELLED
}

enum PaymentMethod {
  CREDIT
  INDIVIDUAL
  BALLER_SUBSCRIPTION
  NONE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum ReportReason {
  SPAM
  OFFENSIVE_BEHAVIOR
  FAKE_ACCOUNT
  MATCH_MANIPULATION
}

enum OpenMatchStatus {
  OPEN
  BOOKED
  CANCELLED
}

enum NotificationType {
  MATCH_READY
  RESULT_CONFIRMED
  RESULT_DISPUTED
  TOURNAMENT_STARTING
  TOURNAMENT_ANNOUNCEMENT
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  FOLLOWED
  TOURNAMENT_INVITE
  SPOTS_FILLING
  NEW_TOURNAMENT
}

model User {
  id              String         @id @default(cuid())
  username        String?        @unique  // unique, public-facing, lowercase stored
  displayName     String?        // optional display name shown in UI
  name            String         // kept for backward compat / full name
  email           String         @unique
  phone           String?
  passwordHash    String?
  role            UserRole       @default(PLAYER)
  authProvider    AuthProvider   @default(LOCAL)
  providerId      String?
  avatarUrl       String?
  bio             String?        // max 160 chars
  city            String?
  location        String?        // city/region for discovery
  dateOfBirth     DateTime?
  level           PlayLevel?
  preferredSport  Sport?
  skillLevel      Int?
  sports          Sport[]
  wins            Int            @default(0)
  losses          Int            @default(0)
  matchesPlayed   Int            @default(0)
  onboardingDone  Boolean        @default(false)
  expoPushToken   String?
  isBaller        Boolean        @default(false)
  lookingForMatch Boolean        @default(false)
  lookingForMatchSport Sport?    // which sport they're looking for
  lastActiveAt    DateTime       @default(now())
  usernameChangedAt DateTime?    // enforce 90-day change limit
  suspendedUntil  DateTime?      // temporary suspension
  bannedAt        DateTime?      // permanent ban

  // Privacy settings (all default ON)
  profileVisible     Boolean     @default(true)
  showRating         Boolean     @default(true)
  showMatchHistory   Boolean     @default(true)

  createdAt       DateTime       @default(now())

  registrations        Registration[]
  organizedTournaments Tournament[]            @relation("Organizer")
  sentFriendRequests   Friendship[]            @relation("FriendshipRequester")
  receivedFriendRequests Friendship[]          @relation("FriendshipReceiver")
  following            Follow[]                @relation("Follower")
  followers            Follow[]                @relation("Following")
  notifications        Notification[]
  matchResults         MatchResult[]
  announcements        TournamentAnnouncement[] @relation("AnnouncementAuthor")
  chatMessages         TournamentChat[]
  doublesAsPlayer1     DoublesTeam[]           @relation("Player1")
  doublesAsPlayer2     DoublesTeam[]           @relation("Player2")
  createdOpenMatches   OpenMatch[]             @relation("OpenMatchCreator")
  joinedOpenMatches    OpenMatch[]             @relation("OpenMatchOpponent")

  // New relations
  sportRatings         UserSportRating[]
  blocksGiven          Block[]                 @relation("Blocker")
  blocksReceived       Block[]                 @relation("Blocked")
  reportsMade          Report[]                @relation("Reporter")
  reportsReceived      Report[]                @relation("Reported")
  creditPacks          CreditPack[]
  ballerSubscription   BallerSubscription?
  competitiveMatchesAsA CompetitiveMatch[]     @relation("PlayerA")
  competitiveMatchesAsB CompetitiveMatch[]     @relation("PlayerB")
  transactions         Transaction[]

  @@unique([authProvider, providerId])
  @@index([username])
  @@index([lastActiveAt])
}

model Tournament {
  id              String           @id @default(cuid())
  name            String
  sport           Sport
  format          TournamentFormat
  status          TournamentStatus @default(REGISTRATION_OPEN)
  description     String?
  date            DateTime
  location        String
  venue           String?
  maxPlayers      Int
  entryFee        Int              // in cents (€10.00 = 1000)
  organizerId     String
  coverImageUrl   String?
  rules           String?
  allowDoubles    Boolean          @default(false)
  skillMin        Int?
  skillMax        Int?
  chatEnabled     Boolean          @default(true)
  organizer       User             @relation("Organizer", fields: [organizerId], references: [id])
  registrations   Registration[]
  matches         Match[]
  announcements   TournamentAnnouncement[]
  chatMessages    TournamentChat[]
  doublesTeams    DoublesTeam[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([date])
  @@index([sport, status])
  @@index([organizerId])
}

model Registration {
  id              String   @id @default(cuid())
  userId          String
  tournamentId    String
  stripeSessionId String?
  stripePaymentId String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
  tournament      Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([userId, tournamentId])
  @@index([tournamentId])
}

model Match {
  id           String        @id @default(cuid())
  tournamentId String
  round        Int
  position     Int
  player1Id    String?
  player2Id    String?
  winnerId     String?
  score        String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  team1Id      String?
  team2Id      String?
  scheduledTime DateTime?
  bracket      String?       // 'WINNERS', 'LOSERS', 'GRAND_FINAL' (null for SE/RR)
  tournament   Tournament    @relation(fields: [tournamentId], references: [id])
  results      MatchResult[]

  @@index([tournamentId, round, position])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  receiverId  String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id])
  receiver    User             @relation("FriendshipReceiver", fields: [receiverId], references: [id])

  @@unique([requesterId, receiverId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id])
  following   User     @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model MatchResult {
  id          String   @id @default(cuid())
  matchId     String
  submittedBy String
  winnerId    String
  score       String?
  createdAt   DateTime @default(now())
  match       Match    @relation(fields: [matchId], references: [id])
  submitter   User     @relation(fields: [submittedBy], references: [id])

  @@unique([matchId, submittedBy])
}

model TournamentAnnouncement {
  id           String     @id @default(cuid())
  tournamentId String
  organizerId  String
  message      String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  organizer    User       @relation("AnnouncementAuthor", fields: [organizerId], references: [id])
}

model TournamentChat {
  id           String     @id @default(cuid())
  tournamentId String
  userId       String
  message      String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([tournamentId, createdAt])
}

model DoublesTeam {
  id           String     @id @default(cuid())
  tournamentId String
  player1Id    String
  player2Id    String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  player1      User       @relation("Player1", fields: [player1Id], references: [id])
  player2      User       @relation("Player2", fields: [player2Id], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // e.g. 'ROLE_CHANGE', 'TOURNAMENT_DELETE', 'TOURNAMENT_CANCEL'
  targetType String   // e.g. 'USER', 'TOURNAMENT', 'MATCH'
  targetId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model OpenMatch {
  id           String          @id @default(cuid())
  creatorId    String
  opponentId   String?
  sport        Sport
  location     String
  venue        String?
  notes        String?
  scheduledFor DateTime
  status       OpenMatchStatus @default(OPEN)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  creator      User            @relation("OpenMatchCreator", fields: [creatorId], references: [id])
  opponent     User?           @relation("OpenMatchOpponent", fields: [opponentId], references: [id])

  @@index([status, scheduledFor])
  @@index([creatorId, status])
  @@index([opponentId, status])
}

// ── Per-sport ELO rating ──
model UserSportRating {
  id              String   @id @default(cuid())
  userId          String
  sport           Sport
  rating          Float    @default(3.0)  // 0.000 - 10.000
  matchesPlayed   Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  winStreak       Int      @default(0)
  bestRating      Float    @default(3.0)
  lastMatchDate   DateTime?
  lastDecayDate   DateTime?  // for inactivity decay tracking
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, sport])
  @@index([sport, rating(sort: Desc)])
  @@index([userId])
}

// ── Rating history entries ──
model RatingHistory {
  id              String   @id @default(cuid())
  userId          String
  sport           Sport
  opponentId      String
  opponentRating  Float
  result          String   // "WIN" or "LOSS"
  delta           Float
  newRating       Float
  matchId         String   // CompetitiveMatch id
  createdAt       DateTime @default(now())

  @@index([userId, sport, createdAt(sort: Desc)])
}

// ── Competitive match (casual or ranked) ──
model CompetitiveMatch {
  id               String                  @id @default(cuid())
  type             MatchType
  sport            Sport
  format           MatchFormat             @default(SINGLES)
  status           CompetitiveMatchStatus  @default(CREATED)

  // Player A
  playerAId        String
  playerARatingBefore Float?
  playerARatingAfter  Float?
  playerAPaymentMethod PaymentMethod       @default(NONE)
  playerACreditId  String?
  playerATransactionId String?
  playerAConfirmed Boolean                 @default(false)

  // Player B
  playerBId        String?
  playerBRatingBefore Float?
  playerBRatingAfter  Float?
  playerBPaymentMethod PaymentMethod       @default(NONE)
  playerBCreditId  String?
  playerBTransactionId String?
  playerBConfirmed Boolean                 @default(false)

  // Result
  winnerId         String?
  disputed         Boolean                 @default(false)
  score            String?

  // Timing
  resultDeadline   DateTime?  // 24h after match becomes active
  createdAt        DateTime                @default(now())
  completedAt      DateTime?

  playerA          User                    @relation("PlayerA", fields: [playerAId], references: [id])
  playerB          User?                   @relation("PlayerB", fields: [playerBId], references: [id])

  @@index([playerAId, status])
  @@index([playerBId, status])
  @@index([sport, status])
  @@index([status, createdAt])
}

// ── Block system ──
model Block {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  reason      String?
  createdAt   DateTime @default(now())
  blocker     User     @relation("Blocker", fields: [blockerId], references: [id])
  blocked     User     @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

// ── Report system ──
model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reportedId  String
  reason      ReportReason
  description String?
  resolved    Boolean      @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?      // admin user id
  createdAt   DateTime     @default(now())
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
  reported    User         @relation("Reported", fields: [reportedId], references: [id])

  @@index([reportedId, resolved])
  @@index([resolved, createdAt])
}

// ── Credit packs ──
model CreditPack {
  id               String   @id @default(cuid())
  userId           String
  packSize         Int      // 10, 25, or 50
  creditsRemaining Int
  pricePaid        Int      // in cents
  stripeTransactionId String   @unique
  purchasedAt      DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Baller subscription ──
model BallerSubscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String
  stripeCustomerId     String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  user                 User               @relation(fields: [userId], references: [id])
}

// ── Transaction audit trail ──
model Transaction {
  id              String   @id @default(cuid())
  userId          String
  type            String   // MATCH_PAYMENT, CREDIT_PURCHASE, CREDIT_CONSUMPTION, SUBSCRIPTION_CHARGE, REFUND
  amount          Int      // in cents, positive = charge, negative = refund
  description     String
  matchId         String?  // CompetitiveMatch id if applicable
  creditPackId    String?
  stripePaymentId String?
  idempotencyKey  String?  @unique
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([matchId])
}

// ── Webhook idempotency ──
model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())

  @@index([stripeEventId])
}
